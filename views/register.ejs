<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body class="login-body">
    <div class="container">
      <header><%- include('./partials/nav.ejs') %></header>

      <div class="auth-wrapper">
        <div class="login-card">
          <h2 class="login-header">Welcome To Arshcon & Form 👋</h2>
          <p class="login-subtitle">Register to continue</p>

          <form class="login-form" action="/api/register" method="POST">
            <input
              type="text"
              name="name"
              placeholder="Enter Full Name"
              required
            />
            <input
              type="email"
              name="email"
              placeholder="Email Address"
              required
            />
            <input
              type="password"
              name="password"
              placeholder="Password"
              required
            />

            <button class="login-button" type="submit">Register</button>
          </form>
        </div>
      </div>

      <%- include('./partials/footer.ejs') %>
    </div>
  </body>
</html>
