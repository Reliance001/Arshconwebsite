<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body>
    <div class="container">
      <header><%- include('./partials/nav.ejs') %></header>
      <main>
        <!-- Hero Section -->
        <section class="service-hero">

    <div class="hero-overlay"></div>

    <div class="container">

        <div class="hero-content">

            <span class="hero-small">OUR</span>

            <h1>SERVICES</h1>

            <div class="hero-line"></div>

            <p>
                Comprehensive construction solutions designed to bring your
                dream home to life with quality craftsmanship and excellence.
            </p>

            <a href="/api/contact" class="hero-btn">
                BUILT FOR LIFE. EVERY TIME.
                <i class="bi bi-arrow-right"></i>
            </a>

        </div>

    </div>

</section>

        <!-- Services Section -->
        <section class="services">
          <div class="container">
            <h2 class="section-title">What We Offer</h2>
            <div class="services-grid">
              <!-- Service Item 1 -->
              <div class="service-item">
                <img src="/Images/drawing.png" alt="Architectural Design" />
                <h3>Architectural Design</h3>
                <p>
                  We craft innovative and functional architectural designs
                  tailored to your needs.
                </p>
              </div>
              <!-- Service Item 2 -->
              <div class="service-item">
                <img src="/Images/architectural.png" alt="Structural Design" />
                <h3>Structural Design</h3>
                <p>
                  Our experts ensure solid and well-engineered structures that
                  last a lifetime.
                </p>
              </div>
              <!-- Service Item 3 -->
              <div class="service-item">
                <img src="/Images/construction.png" alt="Construction" />
                <h3>Construction</h3>
                <p>
                  We bring projects to life with precision and high-quality
                  craftsmanship.
                </p>
              </div>
              <!-- Service Item 4 -->
              <div class="service-item">
                <img src="/Images/living-room.png" alt="Interior Design" />
                <h3>Interior Design</h3>
                <p>
                  We create elegant and functional interiors that enhance
                  everyday living.
                </p>
              </div>
              <!-- Service Item 5 -->
              <div class="service-item">
                <img src="/Images/rental.png" alt="Real Estate" />
                <h3>Real Estate</h3>
                <p>
                  Helping you find, buy, or develop the perfect property for
                  your needs.
                </p>
              </div>
              <div class="service-item">
                <img src="/Images/handshake.png" alt="Joint Venture Image" />
                <h3>Joint Venture</h3>
                <p>
                  We can partner with you to develop a profitable property
                  investment.
                </p>
              </div>
            </div>
          </div>
        </section>
      </main>
      <!------------------ Footer Section ---------------------->
      <%- include('./partials/footer.ejs') %>
    </div>
  </body>
</html>
