<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>

  <body>
    <div class="container">

      <header>
        <%- include('./partials/nav.ejs') %>
      </header>

      <!-- Hero -->
      <section class="project-hero">

        <img
          src="<%= project.banner?.url || '/images/default-project.jpg' %>"
          alt="<%= project.title %>"
        />

        <div class="hero-overlay">
          <h1><%= project.title %></h1>
          <p><%= project.category %></p>
        </div>

      </section>

      <!-- Project Details -->
      <section class="project-details">

        <!-- Meta -->
        <div class="project-meta">

          <p>
            <strong>Location:</strong>
            <%= project.location %>
          </p>

          <p>
            <strong>Status:</strong>
            <%= project.status %>
          </p>

          <p>
            <strong>Author:</strong>
            <%= project.author %>
          </p>

          <p>
            <strong>Completion Date:</strong>

            <%= new Date(project.completionDate)
              .toLocaleDateString(
                'en-NG',
                {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric'
                }
              ) %>

          </p>

        </div>

        <!-- Description -->
        <div class="project-about">

          <h2>About the Project</h2>

          <p id="project-description">
            <%- project.description %>
          </p>

        </div>

        <!-- Gallery -->
        <% if (project.gallery?.length) { %>

          <div class="project-gallery mt-5">

            <h2 class="mb-4">
              Project Gallery
            </h2>

            <div class="gallery-grid">

              <% project.gallery.forEach(image => { %>

                <img
                  src="<%= image.url %>"
                  alt="<%= project.title %>"
                  class="gallery-image"
                />

              <% }) %>

            </div>

          </div>

        <% } %>

        <!-- Testimonial -->
        <% if (
          project.testimonial?.text 
        ) { %>

          <div class="testimonial mt-5">

            <h3>
              Client Testimonial
            </h3>

            <p>
              <%= project.testimonial.text %>
            </p>

          </div>

        <% } %>

        <!-- CTA -->
        <div class="cta mb-2">

          <h2>
            Interested in a Similar Project?
          </h2>

          <p>
            Contact us to discuss your next big idea!
          </p>

          <a
            href="/api/contact"
            class="pD-btn"
          >
            Get in Touch
          </a>

        </div>

      </section>

      <%- include('./partials/footer.ejs') %>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>